  END
  PATCH_IF (csr_hits != csr_cutn_bd2010) BEGIN
    PATCH_FAIL ~chriz-sod-remix comp230: BD2010.are matched %csr_hits% of %csr_cutn_bd2010% cut-list actors. The placed actors differ from the verified layout (another mod?) - regenerate lib/comp230_lists.tpa before installing.~
  END
BUT_ONLY

// ------------------------------------------------------------
// 230.4 — the XP ledger chunk on the Boareskyr resolution
// ------------------------------------------------------------
EXTEND_TOP ~bd2000.bcs~ ~chriz-sod-remix/baf/csr230xp.baf~ EVALUATE_BUFFER
