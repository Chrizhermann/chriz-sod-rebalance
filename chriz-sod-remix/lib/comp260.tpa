// ------------------------------------------------------------
// 260.6 — the XP ledger chunk on the chapter-11 transition
// ------------------------------------------------------------
// Rides the guaranteed 20,000/char chapter award in BD4000.bcs
// (IncrementChapter("chptxt11") block) — fires exactly once, after
// every one of the five maps was available. AddexperienceParty
// DIVIDES among living party members (user-verified in-game
// 2026-07-12), so the chunk is the party-total cut * 0.8 and the
// engine splits it like the kill XP it replaces.
COPY_EXISTING ~bd4000.bcs~ ~override~
  DECOMPILE_AND_PATCH BEGIN
    COUNT_REGEXP_INSTANCES ~AddXPObject(Player1,20000)~ csr_cnt_xp
    PATCH_IF NOT (csr_cnt_xp = 1) BEGIN
      PATCH_FAIL ~chriz-sod-remix comp260: expected exactly one AddXPObject(Player1,20000) in BD4000.bcs, found %csr_cnt_xp%. The chapter-11 transition block differs from the verified layout.~
    END
    REPLACE_TEXTUALLY ~AddXPObject(Player1,20000)~
~AddXPObject(Player1,20000)
    AddexperienceParty(%csr_xp_chunk_260%)~
  END
BUT_ONLY
