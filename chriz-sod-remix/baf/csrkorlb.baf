  !GlobalTimerNotExpired("BD_Cast","LOCALS")
  CheckStat(Myself,0,MINORGLOBE)
  HasItem("SCRL1Z",Myself)
  CheckStatLT(Myself,50,SPELLFAILUREMAGE)
  !CheckStatGT(Myself,0,CLERIC_INSECT_PLAGUE)
  !StateCheck(Myself,STATE_SILENCED)
THEN
  RESPONSE #100
    SetInterrupt(FALSE)
    SetGlobalTimer("BD_Cast","LOCALS",ONE_ROUND)
    DisplayStringHead(Myself,266958)  // ~*uses a scroll*~
    DestroyItem("SCRL1Z")
    SpellNoDec(Myself,WIZARD_MINOR_GLOBE_OF_INVULNERABILITY)
    SetInterrupt(TRUE)
END

// Protection from Elemental Energy scroll, ported from BDSHKORL.baf:87-104
// (same gate replacement as above)
IF
  Allegiance(Myself,ENEMY)
  HasItem("SCRL6H",Myself)
  !GlobalTimerNotExpired("BD_Cast","LOCALS")
  OR(2)
    StateCheck(Myself,STATE_MIRRORIMAGE)
    !Range(NearestEnemyOf(Myself),30)
  !StateCheck(Myself,STATE_REALLY_DEAD)
THEN
  RESPONSE #100
    SetInterrupt(FALSE)
    SetGlobalTimer("BD_Cast","LOCALS",ONE_ROUND)
    DisplayStringHead(Myself,266958)  // ~*uses a scroll*~
    DestroyItem("SCRL6H")
    SpellNoDec(Myself,WIZARD_PROTECTION_FROM_FIRE)
    SetInterrupt(TRUE)
END

// Potion of Clarity, ported from BDSHKORL.baf:106-123
IF
  Allegiance(Myself,ENEMY)
  HasItem("POTN21",Myself)
  !CheckSpellState(Myself,POTION_OF_CLARITY)
  DifficultyGT(EASY)
  OR(2)
    StateCheck(Myself,STATE_MIRRORIMAGE)
    !Range(NearestEnemyOf(Myself),30)
  !StateCheck(Myself,STATE_REALLY_DEAD)
THEN
  RESPONSE #100
    SetInterrupt(FALSE)
    SetGlobalTimer("BD_Cast","LOCALS",ONE_ROUND)
    UseItem("POTN21",Myself)
    DisplayStringHead(Myself,256560)  // ~*quaffs a potion*~
    SetInterrupt(TRUE)
END

// Haste an unhasted ally, ported from BDSHKORL.baf:236-254
IF
  DifficultyGT(EASY)
  OR(2)
    !GlobalTimerNotExpired("BD_Cast","LOCALS")
    CheckStatGT(Myself,0,AURACLEANSING)
  HaveSpell(WIZARD_HASTE)
  See([EVILCUTOFF])
  !StateCheck(LastSeenBy(Myself),STATE_NOT_TARGETABLE)
  !StateCheck(LastSeenBy(Myself),STATE_DISABLED)
  CheckStat(LastSeenBy(Myself),0,IMPROVEDHASTE)
  !StateCheck(LastSeenBy(Myself),STATE_HASTED)
  CheckStatLT(Myself,50,SPELLFAILUREMAGE)
  !CheckStatGT(Myself,0,CLERIC_INSECT_PLAGUE)
  !StateCheck(Myself,STATE_SILENCED)
THEN
  RESPONSE #100
    SetGlobalTimer("BD_Cast","LOCALS",ONE_ROUND)
    Spell(LastSeenBy(Myself),WIZARD_HASTE)
END

// NEW: Hold Monster (L5 book extension, design 01-prologue.md sec 2a); guard set
// copied from the vanilla Confusion block so the counterplay is identical
IF
  DifficultyGT(EASY)
  OR(2)
    !GlobalTimerNotExpired("BD_Cast","LOCALS")
    CheckStatGT(Myself,0,AURACLEANSING)
  HaveSpell(WIZARD_HOLD_MONSTER)
  See([GOODCUTOFF])
  !General(LastSeenBy(Myself),UNDEAD)
  !StateCheck(LastSeenBy(Myself),STATE_NOT_TARGETABLE)
  !StateCheck(LastSeenBy(Myself),STATE_DISABLED)
  CheckStatLT(LastSeenBy(Myself),50,RESISTMAGIC)
  CheckStatGT(LastSeenBy(Myself),-2,SAVEVSSPELL)
  !CheckStatGT(LastSeenBy(Myself),0,CLERIC_FREE_ACTION)
  !CheckStatGT(LastSeenBy(Myself),0,CLERIC_CHAOTIC_COMMANDS)
  !CheckStat(LastSeenBy(Myself),5,WIZARD_SPELL_IMMUNITY)
  CheckStatLT(Myself,50,SPELLFAILUREMAGE)
  !CheckStatGT(Myself,0,CLERIC_INSECT_PLAGUE)
  !StateCheck(Myself,STATE_SILENCED)
THEN
