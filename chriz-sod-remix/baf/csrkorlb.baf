// chriz-sod-remix component 170 - csrkorlb: Korlasz's no-SCS combat brain (race slot).
// Port of her vanilla personal brain BDSHKORL.baf (research 10d section 1; block line
// numbers cited below refer to research/data/sod_baf/BDSHKORL.baf) with:
//   - every AreaCheck("BD0130")/Massive_Door gate dropped (the fight now lives in BD0116),
//   - the talk-first/surrender machinery (:12-75) NOT ported - design 01-prologue.md
//     section 2 locks "NO surrender/parley; a real fight to the death",
//   - the signature-sequencer fire block added (dw#mg437 HaveSpellRES pattern, 10d/11a),
//   - one Hold Monster and one Flame Arrow block added for the L5/L6 book extension,
//   - 6x nearest-rank spam per spell condensed to the first 2-3 ranks (a 6-slot party
//     never needs rank 4-6; keeps the script reviewable).
// Every cast is HaveSpell()-guarded (vanilla property), so this brain is also safe as
// the shared fallback brain for csrpori (Mage 8): missing spells silently no-op, the
// scroll/potion blocks are HasItem()-guarded and he carries none.
// Only vanilla-EE IDS symbols are used - this file must compile WITHOUT SCS installed.

// out-of-combat 8-hour reset, ported from BDSHKORL.baf:1-10
IF
  !GlobalTimerNotExpired("BD_Rest","LOCALS")
THEN
  RESPONSE #100
    SetGlobalTimer("BD_Rest","LOCALS",EIGHT_HOURS)
    ApplySpell(Myself,RESTORE_FULL_HEALTH)
    SetGlobal("BD_MSeq","LOCALS",0)
    Rest()
END

// NEW self-arming block: vanilla relied on the BDENSHTV class script to set BD_Engaged;
// her dialog-driven Enemy() in BD0116 must never leave her parked on the gate below if
// that engage path misses, so arm explicitly on first sight of an opponent.
IF
  Allegiance(Myself,EVILCUTOFF)
  Global("BD_Engaged","LOCALS",0)
  See([GOODCUTOFF])
THEN
  RESPONSE #100
    SetGlobal("BD_Engaged","LOCALS",1)
    SetGlobalTimer("BD_Rest","LOCALS",EIGHT_HOURS)
    Continue()
END

// master combat gate, ported from BDSHKORL.baf:125-134
IF
  OR(4)
    !Allegiance(Myself,EVILCUTOFF)
    StateCheck(Myself,STATE_IMMOBILE)
    StateCheck(Myself,STATE_REALLY_DEAD)
    Global("BD_Engaged","LOCALS",0)
THEN
  RESPONSE #100
    NoAction()
END

// ported from BDSHKORL.baf:136-142
IF
  !InActiveArea(Myself)
  !Range(NearestEnemyOf(Myself),30)
THEN
  RESPONSE #100
    NoAction()
END

// ported from BDSHKORL.baf:144-149
IF
  StateCheck(Myself,STATE_PANIC)
THEN
  RESPONSE #100
    RandomWalkContinuous()
END

// emulated Minor Sequencer (instant Mirror Image + Shield), BDSHKORL.baf:151-164
// minus the AreaCheck. NOTE: shared with csrpori - ReallyForceSpell ignores the book,
// so he also opens with MI+Shield; accepted (he is the Mirror Image support caster).
IF
  Allegiance(Myself,ENEMY)
  Global("BD_MSeq","LOCALS",0)
  !GlobalTimerNotExpired("BD_Cast","LOCALS")
THEN
  RESPONSE #100
    SetGlobal("BD_MSeq","LOCALS",1)
    SetGlobalTimer("BD_Cast","LOCALS",ONE_ROUND)
    DisplayString(Myself,226469)  // ~Minor Sequencer~ (vanilla strref, BDSHKORL.baf:160)
    SetSequence(SEQ_CAST)
    ReallyForceSpell(Myself,WIZARD_MIRROR_IMAGE)
    ReallyForceSpell(Myself,WIZARD_SHIELD)
END

// NEW: signature Spell Sequencer, no-SCS variant. Mirrors the install-generated
// dw#mg437 dw#ms3 block (dumped from the dev install, see docs/research/10d and
// lib/comp170.tpa): HaveSpellRES marker -> ReallyForceSpellRES of the combined SPL
// (which burns the marker via op172 -> fires exactly once) + forced component casts.
// Sets both BD_Cast (this brain's rhythm) and castspell (SCS convention) timers.
IF
  !GlobalTimerNotExpired("BD_Cast","LOCALS")
  HaveSpellRES("csrseq1")
  Allegiance(Myself,ENEMY)
  See(NearestEnemyOf(Myself))
  !StateCheck(NearestEnemyOf(Myself),STATE_NOT_TARGETABLE)
THEN
  RESPONSE #100
    SetGlobalTimer("BD_Cast","LOCALS",ONE_ROUND)
    SetGlobalTimer("castspell","LOCALS",ONE_ROUND)
    ReallyForceSpellRES("csrseq1b",NearestEnemyOf(Myself))
    ReallyForceSpell(NearestEnemyOf(Myself),WIZARD_SLOW)
    SmallWait(1)
    ReallyForceSpell(NearestEnemyOf(Myself),WIZARD_CONFUSION)
    SmallWait(1)
    ReallyForceSpell(NearestEnemyOf(Myself),WIZARD_GLITTERDUST)
END

// Vocalize scroll, ported from BDSHKORL.baf:166-178 (revived by restoring SCRL3G)
IF
  StateCheck(Myself,STATE_SILENCED)
  HasItem("SCRL3G",Myself)
  !GlobalTimerNotExpired("BD_Cast","LOCALS")
THEN
  RESPONSE #100
    SetInterrupt(FALSE)
    SetGlobalTimer("BD_Cast","LOCALS",ONE_ROUND)
    DisplayStringHead(Myself,266958)  // ~*uses a scroll*~
    DestroyItem("SCRL3G")
    SpellNoDec(Myself,WIZARD_VOCALIZE)
    SetInterrupt(TRUE)
END

// Stoneskin recast, ported from BDSHKORL.baf:180-193
IF
  OR(2)
    !GlobalTimerNotExpired("BD_Cast","LOCALS")
    CheckStatGT(Myself,0,AURACLEANSING)
  CheckStatLT(Myself,1,STONESKINS)
  HaveSpell(WIZARD_STONE_SKIN)
  CheckStatLT(Myself,50,SPELLFAILUREMAGE)
  !CheckStatGT(Myself,0,CLERIC_INSECT_PLAGUE)
  !StateCheck(Myself,STATE_SILENCED)
THEN
  RESPONSE #100
    SetGlobalTimer("BD_Cast","LOCALS",ONE_ROUND)
    Spell(Myself,WIZARD_STONE_SKIN)
END

// Mirror Image, ported from BDSHKORL.baf:195-217
IF
  OR(2)
    !GlobalTimerNotExpired("BD_Cast","LOCALS")
    CheckStatGT(Myself,0,AURACLEANSING)
  !StateCheck(Myself,STATE_MIRRORIMAGE)
  HaveSpell(WIZARD_MIRROR_IMAGE)
  !CheckStatGT(Myself,0,WIZARD_PROTECTION_FROM_MAGIC_WEAPONS)
  CheckStatLT(Myself,50,SPELLFAILUREMAGE)
  !CheckStatGT(Myself,0,CLERIC_INSECT_PLAGUE)
  !StateCheck(Myself,STATE_SILENCED)
  !CheckStatGT(Player1,0,TRUE_SIGHT)
  !CheckStatGT(Player2,0,TRUE_SIGHT)
  !CheckStatGT(Player3,0,TRUE_SIGHT)
  !CheckStatGT(Player4,0,TRUE_SIGHT)
  !CheckStatGT(Player5,0,TRUE_SIGHT)
  !CheckStatGT(Player6,0,TRUE_SIGHT)
  !CheckStatGT([GOODCUTOFF.0.PLANATAR],0,TRUE_SIGHT)
  !CheckStatGT([GOODCUTOFF.0.DARKPLANATAR],0,TRUE_SIGHT)
THEN
  RESPONSE #100
    SetGlobalTimer("BD_Cast","LOCALS",ONE_ROUND)
    Spell(Myself,WIZARD_MIRROR_IMAGE)
END

// Minor Globe scroll, ported from BDSHKORL.baf:219-234; the vanilla
